{
	"name": "@elsikora/eslint-config",
	"version": "3.9.1",
	"description": "ESLint configuration vision of ElsiKora",
	"keywords": [
		"eslint",
		"eslint-config",
		"eslint-plugin",
		"typescript",
		"nestjs",
		"decorator",
		"sort",
		"import",
		"package.json",
		"perfectionist",
		"sonarjs",
		"typeorm",
		"unicorn",
		"unused-imports",
		"yml",
		"jsonc",
		"yaml"
	],
	"homepage": "https://github.com/ElsiKora/ESLint-Config#readme",
	"bugs": {
		"url": "https://github.com/ElsiKora/ESLint-Config/issues"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/ElsiKora/ESLint-Config"
	},
	"license": "MIT",
	"author": "ElsiKora",
	"sideEffects": false,
	"type": "module",
	"exports": {
		".": {
			"import": "./dist/esm/index.js",
			"require": "./dist/cjs/index.js"
		}
	},
	"files": [
		"./dist"
	],
	"scripts": {
		"branch": "npx @elsikora/git-branch-lint -b",
		"prebuild": "rimraf dist",
		"build": "npm run prebuild && rollup -c",
		"postbuild": "rimraf dist/esm/node_modules dist/cjs/node_modules",
		"build:test": "npm run prebuild && rollup -c rollup.test.config.js",
		"postbuild:test": "rimraf dist/esm/node_modules dist/cjs/node_modules",
		"ci": "npm run test && npm run build && npm run semantic-release",
		"commit": "cz",
		"dev": "rollup -c -w",
		"format": "prettier --check .",
		"format:fix": "prettier --write .",
		"lint": "eslint ./",
		"lint:all": "npm run lint && npm run lint:types",
		"lint:all:fix": "npm run lint:fix && npm run lint:types:fix",
		"lint:fix": "eslint --fix ./",
		"lint:types": "tsc --noEmit -p tsconfig.lint.json",
		"lint:types:fix": "tsc --noEmit --skipLibCheck",
		"prepare": "husky",
		"release": "semantic-release",
		"test:all": "npm run test:unit && npm run test:e2e",
		"test:e2e": "npm run build:test && vitest --config vitest.e2e.config.js --typecheck.tsconfig tsconfig.json",
		"test:unit": "vitest run test/unit --config vitest.unit.config.js"
	},
	"config": {
		"commitizen": {
			"path": "@elsikora/commitizen-plugin-commitlint-ai"
		}
	},
	"dependencies": {
		"@elsikora/eslint-plugin-markdown": "^6.2.3",
		"@eslint/compat": "^2.1.0",
		"@eslint/js": "^10.0.1",
		"@stylistic/eslint-plugin": "^5.10.0",
		"@typescript-eslint/eslint-plugin": "^8.59.4",
		"@typescript-eslint/parser": "^8.59.4",
		"@typescript-eslint/utils": "^8.59.4",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-check-file": "^3.3.1",
		"eslint-plugin-jsonc": "^3.1.2",
		"eslint-plugin-no-secrets": "^2.3.3",
		"eslint-plugin-package-json": "^1.1.0",
		"eslint-plugin-perfectionist": "^5.9.0",
		"eslint-plugin-prettier": "^5.5.5",
		"eslint-plugin-regexp": "^3.1.0",
		"eslint-plugin-sonarjs": "^4.0.3",
		"eslint-plugin-tailwindcss": "^3.18.3",
		"eslint-plugin-unicorn": "^64.0.0",
		"eslint-plugin-yml": "^3.3.2",
		"globals": "^17.6.0",
		"typescript-eslint": "^8.59.4"
	},
	"devDependencies": {
		"@commitlint/cli": "^21.0.1",
		"@commitlint/config-conventional": "^21.0.1",
		"@commitlint/format": "^21.0.1",
		"@commitlint/types": "^21.0.1",
		"@conarti/eslint-plugin-feature-sliced": "^2.0.0-rc.15",
		"@elsikora/commitizen-plugin-commitlint-ai": "^3.0.1",
		"@elsikora/eslint-plugin-css": "^0.6.3",
		"@elsikora/eslint-plugin-nestjs-typed": "^3.1.0",
		"@elsikora/eslint-plugin-sort-decorators": "^0.2.9",
		"@elsikora/git-branch-lint": "^1.2.2",
		"@eslint-react/eslint-plugin": "^5.8.3",
		"@eslint/core": "^1.2.1",
		"@next/eslint-plugin-next": "^16.2.6",
		"@rollup/plugin-typescript": "^12.3.0",
		"@saithodev/semantic-release-backmerge": "^4.0.1",
		"@semantic-release/changelog": "^6.0.3",
		"@semantic-release/commit-analyzer": "^13.0.1",
		"@semantic-release/git": "^10.0.1",
		"@semantic-release/github": "^12.0.8",
		"@semantic-release/npm": "^13.1.5",
		"@semantic-release/release-notes-generator": "^14.1.1",
		"@tanstack/eslint-plugin-query": "^5.100.11",
		"@tanstack/eslint-plugin-router": "^1.162.0",
		"@tanstack/react-query": "^5.100.11",
		"@tanstack/react-router": "^1.170.6",
		"@vitest/coverage-v8": "^4.1.7",
		"commitizen": "^4.3.1",
		"conventional-changelog-conventionalcommits": "^9.3.1",
		"esbuild": "^0.28.0",
		"eslint": "^10.4.0",
		"eslint-plugin-fsd-lint": "^1.2.1",
		"eslint-plugin-i18next": "^6.1.4",
		"eslint-plugin-jsdoc": "^63.0.0",
		"eslint-plugin-jsx-a11y-x": "^0.2.0",
		"eslint-plugin-n": "^18.0.1",
		"eslint-plugin-storybook": "^10.4.0",
		"eslint-plugin-typeorm-typescript": "^0.5.4",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.5",
		"memfs": "^4.57.2",
		"next": "^16.2.6",
		"nextra": "^4.6.1",
		"nextra-theme-docs": "^4.6.1",
		"prettier": "^3.8.3",
		"react": "^19.2.6",
		"react-dom": "^19.2.6",
		"rimraf": "^6.1.3",
		"rollup": "^4.60.4",
		"rollup-plugin-dts-path-alias": "^0.0.3",
		"rollup-plugin-generate-package-json": "^3.2.0",
		"semantic-release": "^25.0.3",
		"semantic-release-github-pullrequest": "^1.3.0",
		"storybook": "^10.4.0",
		"tslib": "^2.8.1",
		"typescript": "^6.0.3",
		"vite-tsconfig-paths": "^6.1.1",
		"vitest": "^4.1.7"
	},
	"peerDependencies": {
		"@conarti/eslint-plugin-feature-sliced": "^2.0.0-rc.15",
		"@elsikora/eslint-plugin-nestjs-typed": "^3.1.0",
		"@elsikora/eslint-plugin-sort-decorators": "^0.2.9",
		"@eslint-react/eslint-plugin": "^5.8.3",
		"@next/eslint-plugin-next": "*",
		"@tanstack/eslint-plugin-query": "^5.100.11",
		"@tanstack/eslint-plugin-router": "^1.162.0",
		"eslint-plugin-fsd-lint": "^1.2.1",
		"eslint-plugin-i18next": "^6.1.4",
		"eslint-plugin-jsx-a11y-x": "^0.2.0",
		"eslint-plugin-n": "^18.0.1",
		"eslint-plugin-storybook": "^10.4.0",
		"eslint-plugin-typeorm-typescript": "^0.5.4"
	},
	"peerDependenciesMeta": {
		"@conarti/eslint-plugin-feature-sliced": {
			"optional": true
		},
		"@elsikora/eslint-plugin-nestjs-typed": {
			"optional": true
		},
		"@elsikora/eslint-plugin-sort-decorators": {
			"optional": true
		},
		"@eslint-react/eslint-plugin": {
			"optional": true
		},
		"@next/eslint-plugin-next": {
			"optional": true
		},
		"@tanstack/eslint-plugin-query": {
			"optional": true
		},
		"@tanstack/eslint-plugin-router": {
			"optional": true
		},
		"eslint-plugin-fsd-lint": {
			"optional": true
		},
		"eslint-plugin-i18next": {
			"optional": true
		},
		"eslint-plugin-jsx-a11y-x": {
			"optional": true
		},
		"eslint-plugin-n": {
			"optional": true
		},
		"eslint-plugin-storybook": {
			"optional": true
		},
		"eslint-plugin-typeorm-typescript": {
			"optional": true
		}
	},
	"publishConfig": {
		"access": "public"
	}
}
